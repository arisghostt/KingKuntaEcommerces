# ─────────────────────────────────────────────────────────
# SÉCURITÉ DJANGO
# ─────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-remplacer-en-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,localhost:3000,127.0.0.1:3000

# ─────────────────────────────────────────────────────────
# BASE DE DONNÉES — Neon PostgreSQL (serverless)
# ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-proud-frog-afe4kikk-pooler.c-2.us-west-2.aws.neon.tech/dbname?sslmode=require

# Optimisation connexion Neon
DB_CONN_MAX_AGE=0
DB_CONNECT_TIMEOUT=15
DB_KEEPALIVES=1
DB_KEEPALIVES_IDLE=30
DB_KEEPALIVES_INTERVAL=10
DB_KEEPALIVES_COUNT=5

# ─────────────────────────────────────────────────────────
# CLOUDFLARE R2 — Stockage de fichiers & médias
# ─────────────────────────────────────────────────────────
# IMPORTANT : Laisser vides pour désactiver R2 (fallback local en développement)
#
# Sources :
#   - R2_ACCESS_KEY: Créer une clé d'accès R2 dans le dashboard Cloudflare
#   - R2_SECRET_KEY: Secret associé à la clé d'accès
#   - R2_ENDPOINT: https://<votre_compte_id>.r2.cloudflarestorage.com
#   - R2_BUCKET_NAME: Nom du bucket créé dans R2
#   - R2_PUBLIC_URL: (Optionnel) Domaine public si bucket public
#                    Format : https://pub-<hash>.r2.dev ou domaine personnalisé

# Clés R2 (obtenir depuis https://dash.cloudflare.com/profile/api-tokens)
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET_NAME=

# URL publique pour servir les fichiers (vider pour URLs signées privées)
R2_PUBLIC_URL=

# Structure du bucket R2 :
#   /products/images/     → Images des produits (300x300, 600x600)
#   /users/avatars/       → Avatars des utilisateurs
#   /documents/           → Factures, PDFs, exports
#   /private/             → Fichiers privés avec signatures temporaires

# ─────────────────────────────────────────────────────────
# NOTES
# ─────────────────────────────────────────────────────────
# - Ne JAMAIS commiter ce fichier dans le code. Renommer en .env
# - Les variables vides désactiveront R2 (stockage local en dev)
# - En production : toutes les variables R2 DOIVENT être définies
# - ALLOWED_HOSTS : ajouter le domaine de production (ex: api.monsite.com)
# - DEBUG : mettre à False en production
# - SECRET_KEY : générer une nouvelle clé cryptographiquement sûre
